# Required for real agents
OPENAI_API_KEY=sk-your-key-here
MODEL_NAME=gpt-4o
# OLLAMA_BASE_URL=http://localhost:11434

# ----- Sponsor integrations (all optional; absent => no-op clients) -----

# ClickHouse (analytics persistence)
# CLICKHOUSE_HOST=localhost
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=default
# CLICKHOUSE_SECURE=false

# Datadog (APM tracing + custom metrics)
# DD_API_KEY=your-datadog-api-key
# DD_APP_KEY=your-datadog-app-key
# DD_SITE=datadoghq.com
# DD_AGENT_HOST=127.0.0.1
# DD_DOGSTATSD_PORT=8125
# DD_SERVICE=mindmesh
# DD_ENV=hackathon
# MINDMESH_TRACE_LOG=false

# Senso (behavioral signal enrichment)
# SENSO_API_KEY=your-senso-api-key
# SENSO_BASE_URL=https://api.senso.ai/v1
